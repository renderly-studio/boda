/* ── Formulari de confirmació (Vindràs?) ── */
(function () {
  const form = document.getElementById('form-rsvp');
  if (!form) return;

  function configuraSiNo(grupId, alTriar) {
    const grup = document.getElementById(grupId);
    if (!grup) return;
    grup.querySelectorAll('button').forEach(b => {
      b.addEventListener('click', () => {
        grup.querySelectorAll('button').forEach(x => x.classList.remove('triat'));
        b.classList.add('triat');
        if (alTriar) alTriar(b.dataset.valor);
      });
    });
  }

  configuraSiNo('rsvp-vindras', valor => {
    document.getElementById('rsvp-bloc-detalls').classList.toggle('visible', valor === 'si');
  });
  configuraSiNo('rsvp-acompanyant', valor => {
    document.getElementById('rsvp-acompanyant-detall').classList.toggle('visible', valor === 'si');
  });
  configuraSiNo('rsvp-nens', valor => {
    document.getElementById('rsvp-nens-detall').classList.toggle('visible', valor === 'si');
  });
  configuraSiNo('rsvp-autocar', valor => {
    document.getElementById('rsvp-autocar-detall').classList.toggle('visible', valor === 'si');
  });
  configuraSiNo('rsvp-dormir');

  const camp = n => form.elements.namedItem(n);

  form.addEventListener('submit', e => {
    e.preventDefault();

    const vindra = (function(){ var e = document.querySelector('#rsvp-vindras .triat'); return e ? e.dataset.valor : null; })();
    const errors = document.getElementById('rsvp-errors');
    if (!camp('nom').value.trim() || !camp('cognoms').value.trim() || !camp('contacte').value.trim() || !vindra) {
      errors.textContent = 'Falta el nom, els cognoms, el contacte o dir-nos si vindràs — completa-ho abans d\'enviar.';
      errors.hidden = false;
      try { errors.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (e) {}
      return;
    }
    errors.hidden = true;

    const dades = {
      nom: camp('nom').value,
      cognoms: camp('cognoms').value,
      contacte: camp('contacte').value,
      vindra,
      menu: camp('menu').value,
      allergies: camp('allergies').value,
      acompanyant: (function(){ var e = document.querySelector('#rsvp-acompanyant .triat'); return e ? e.dataset.valor : null; })(),
      acompanyantNom: camp('acompanyant_nom').value,
      acompanyantCognoms: camp('acompanyant_cognoms').value,
      acompanyantMenu: camp('acompanyant_menu').value,
      acompanyantAllergies: camp('acompanyant_allergies').value,
      nens: (function(){ var e = document.querySelector('#rsvp-nens .triat'); return e ? e.dataset.valor : null; })(),
      nensDetall: camp('nens_detall').value,
      autocar: (function(){ var e = document.querySelector('#rsvp-autocar .triat'); return e ? e.dataset.valor : null; })(),
      autocarQuan: camp('autocar_quan').value,
      dormir: (function(){ var e = document.querySelector('#rsvp-dormir .triat'); return e ? e.dataset.valor : null; })(),
      canco: camp('canco').value,
      especial: camp('especial').value,
    };
    try { localStorage.setItem('rsvp', JSON.stringify(dades)); } catch {}

    /* Enviament directe al correu de Marta i Guille via FormSubmit,
       sense que el convidat hagi d'obrir res. Si la xarxa falla,
       pla B: correu ja redactat. */
    const linies = [
      `Nom: ${dades.nom} ${dades.cognoms}`,
      `Contacte: ${dades.contacte}`,
      `Vindrà: ${dades.vindra === 'si' ? 'Sí' : 'No'}`,
    ];
    if (dades.vindra === 'si') {
      linies.push(
        `Menú: ${dades.menu}`,
        `Al·lèrgies o intoleràncies: ${dades.allergies || '—'}`,
        `Ve amb acompanyant: ${dades.acompanyant === 'si' ? 'Sí' : 'No'}`,
      );
      if (dades.acompanyant === 'si') {
        linies.push(
          `  Nom acompanyant: ${dades.acompanyantNom} ${dades.acompanyantCognoms}`,
          `  Menú acompanyant: ${dades.acompanyantMenu}`,
          `  Al·lèrgies acompanyant: ${dades.acompanyantAllergies || '—'}`,
        );
      }
      linies.push(`Ve amb nens/nenes: ${dades.nens === 'si' ? 'Sí' : 'No'}`);
      if (dades.nens === 'si') linies.push(`  Detall nens: ${dades.nensDetall || '—'}`);
      if (dades.autocar === 'si') linies.push(`Autocar: Sí (${dades.autocarQuan.replace(/-/g, ' ')})`);
      else linies.push(`Autocar: No`);
      linies.push(`Es quedaria a dormir: ${dades.dormir === 'si' ? 'Sí' : dades.dormir === 'no' ? 'No' : '—'}`);
      if (dades.canco) linies.push(`Cançó per a la festa: ${dades.canco}`);
      linies.push(
        `Necessitats especials: ${dades.especial || '—'}`,
      );
    }
    const cosText = linies.join('\n');
    const assumpte = `Confirmació boda ✦ ${dades.nom} ${dades.cognoms}`;
    const gracies = document.getElementById('rsvp-gracies');
    const botoEnviar = form.querySelector('.form-enviar');

    botoEnviar.disabled = true;
    botoEnviar.textContent = 'Enviant…';

    fetch('https://formsubmit.co/ajax/omgenscasem@gmail.com', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        _subject: assumpte,
        _template: 'box',
        _captcha: 'false',
        'Resposta completa': cosText,
      }),
    })
    .then(r => { if (!r.ok) throw new Error('resposta ' + r.status); return r.json(); })
    .then(() => {
      form.querySelectorAll('input, select, textarea, button').forEach(el => el.disabled = true);
      gracies.textContent = 'Rebut! Moltes gràcies — ens veiem a la posta de sol ✦';
      gracies.hidden = false;
      try { gracies.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (e) {}
    })
    .catch(() => {
      /* Pla B: si l'enviament directe falla (sense connexió, bloquejadors...),
         obrim un correu ja redactat perquè la resposta no es perdi mai. */
      botoEnviar.disabled = false;
      botoEnviar.textContent = 'Enviar confirmació';
      gracies.textContent = "No hem pogut enviar-ho directament — s'obrirà el teu correu amb la resposta ja escrita: només cal prémer «enviar».";
      gracies.hidden = false;
      window.location.href = 'mailto:omgenscasem@gmail.com?subject=' + encodeURIComponent(assumpte) + '&body=' + encodeURIComponent(cosText);
    });
  });
})();

/* ── Postes de sol vistes amb nosaltres ── */
try {
