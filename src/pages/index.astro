  const llarg = 300 + Math.random() * 160;
  const fx = Math.cos(angle) * llarg, fy = Math.sin(angle) * llarg;
  const corbat = (Math.random() * 90 - 45);
  const cx = fx / 2 - Math.sin(angle) * corbat, cy = fy / 2 + Math.cos(angle) * corbat;
  fg.style.offsetPath = `path('M0,0 Q ${cx.toFixed(0)},${cy.toFixed(0)} ${fx.toFixed(0)},${fy.toFixed(0)}')`;
  fg.innerHTML = `<div class="cua"></div><div class="cap"><svg viewBox="0 0 26 26"><path d="${DESTELL}"/></svg></div>`;
  celNit.appendChild(fg);
  // Espurnes que va deixant pel camí
  let n = 0;
  const espurnes = setInterval(() => {
    if (++n > 7) { clearInterval(espurnes); return; }
    const r = fg.getBoundingClientRect(), rc = celNit.getBoundingClientRect();
    if (!r.width) return;
    const e = document.createElement('div');
    e.className = 'espurna';
    e.style.left = (r.left - rc.left + 4) + 'px';
    e.style.top = (r.top - rc.top + 4) + 'px';
