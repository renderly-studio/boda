<script is:inline>
/* ── Porta d'entrada: contrasenya. Bloc totalment independent:
     encara que qualsevol altra part fallés, això funciona sol. ── */
(function () {
  var CLAU = 'BODORRIO0207';
  var input = document.getElementById('clau');
  var sobre = document.getElementById('sobre');
  var segell = document.getElementById('segell');
  var pista = document.getElementById('sobre-pista');
  if (!input || !sobre || !segell) return;

  function recorda() { try { localStorage.setItem('clauOk', '1'); } catch (e) {} }
  function recordada() { try { return localStorage.getItem('clauOk') === '1'; } catch (e) { return false; } }

  function desbloqueja() {
    document.body.dataset.clauOk = '1';
    input.classList.add('correcta');
    if (pista) pista.hidden = false;
    recorda();
  }
  function esCorrecta() {
    return input.value.replace(/\s/g, '').toUpperCase() === CLAU;
  }
  function sacseja() {
    input.classList.remove('error');
    void input.offsetWidth;
    input.classList.add('error');
    input.focus();
  }
  function obre() {
    sobre.classList.add('obert');
    document.body.classList.remove('tancat');
  }

  if (recordada()) {
    desbloqueja();
  }

  if (window.innerWidth < 480) { input.placeholder = 'Contrasenya de convidat'; }
  input.addEventListener('input', function () {
    input.classList.remove('error');
    if (esCorrecta()) desbloqueja();
  });
  input.addEventListener('keydown', function (e) {
    if (e.key !== 'Enter') return;
    if (esCorrecta() || document.body.dataset.clauOk === '1') { desbloqueja(); obre(); }
    else sacseja();
  });
  segell.addEventListener('click', function () {
    if (document.body.dataset.clauOk === '1') { obre(); }
    else if (esCorrecta()) { desbloqueja(); obre(); }
    else { sacseja(); }
  });
})();
</script>
<script is:inline>
/* ── Ajust real dels títols d'una línia: es mesuren i s'encongeixen només si cal.
     Compensa que les floritures de la lletra script sobresurten de la caixa del text. ── */
(function () {
  function ajusta(el, factor) {
    if (!el) return;
    el.style.fontSize = '';
    var pare = el.parentElement;
    if (!pare) return;
    var max = pare.clientWidth * factor;
    var mida = parseFloat(getComputedStyle(el).fontSize);
    var seguretat = 60;
    while (el.scrollWidth > max && mida > 12 && seguretat-- > 0) {
      mida -= 1;
      el.style.fontSize = mida + 'px';
    }
  }
  function tots() {
    ajusta(document.querySelector('.titol-nuvis'), 0.86);
    ajusta(document.querySelector('.titol-linia'), 0.92);
  }
  tots();
  window.addEventListener('load', tots);
  window.addEventListener('resize', tots);
  window.addEventListener('orientationchange', tots);
  if (document.fonts && document.fonts.ready && document.fonts.ready.then) {
    document.fonts.ready.then(tots);
  }
})();
</script>
<script is:inline>
/* ── Ajust automàtic dels títols d'una línia: es mesuren de veritat i
     s'escalen fins a cabre al dispositiu, sigui quin sigui. ── */
(function () {
  function ajusta(el) {
    var pare = el.parentElement;
    if (!pare) return;
    var maxAmple = pare.clientWidth * 0.92;
    var mida = Math.min(window.innerWidth * 0.085, 68); // punt de partida generós
    el.style.fontSize = mida + 'px';
    var seguretat = 40;
    while (el.scrollWidth > maxAmple && mida > 13 && seguretat-- > 0) {
      mida -= 1;
      el.style.fontSize = mida + 'px';
    }
  }
  function tots() {
    document.querySelectorAll('.titol-ajusta').forEach(ajusta);
  }
  tots();
  window.addEventListener('resize', tots);
  window.addEventListener('load', tots);
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(tots);
})();
</script>
<script is:inline>
/* ── Auto-encaix de títols: es mostren al màxim que hi cap, mai tallats.
     Té en compte les floritures de la lletra script (marge de seguretat). ── */
(function () {
  function encaixa(el, factor) {
    el.style.fontSize = '';
    var pare = el.parentElement;
    if (!pare) return;
    var disponible = pare.clientWidth * factor;
    if (!disponible) return;
    var mida = parseFloat(getComputedStyle(el).fontSize);
    var seguretat = 0;
    while (el.scrollWidth > disponible && seguretat++ < 30) {
      mida *= 0.94;
      el.style.fontSize = mida.toFixed(1) + 'px';
    }
  }
  function tots() {
    var nuvis = document.querySelectorAll('.titol-nuvis');
    var i;
    for (i = 0; i < nuvis.length; i++) encaixa(nuvis[i], 0.86);
    var linies = document.querySelectorAll('.titol-linia');
    for (i = 0; i < linies.length; i++) encaixa(linies[i], 0.9);
  }
  if (document.fonts && document.fonts.ready) { document.fonts.ready.then(tots); }
  window.addEventListener('load', tots);
  window.addEventListener('resize', tots);
  window.addEventListener('orientationchange', tots);
  tots();
})();
</script>
<script is:inline>
/* ── Encaix de títols d'una línia: mai sobrepassar la pantalla (ES5) ── */
(function () {
  function encaixa(el) {
    if (!el) return;
    el.style.fontSize = '';
    var mida = parseFloat(window.getComputedStyle(el).fontSize);
    var seguretat = 24;
    while (el.scrollWidth > el.clientWidth + 1 && seguretat-- > 0 && mida > 12) {
      mida *= 0.94;
      el.style.fontSize = mida + 'px';
    }
  }
  function tots() {
    var seleccions = document.querySelectorAll('.titol-nuvis, h2.titol.titol-linia');
    for (var i = 0; i < seleccions.length; i++) encaixa(seleccions[i]);
  }
  var temps;
  function programat() { clearTimeout(temps); temps = setTimeout(tots, 150); }
  if (document.fonts && document.fonts.ready && document.fonts.ready.then) {
    document.fonts.ready.then(tots);
  }
  window.addEventListener('load', tots);
  window.addEventListener('resize', programat);
  window.addEventListener('orientationchange', programat);
  tots();
})();
</script>
