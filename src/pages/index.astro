<script is:inline>
/* ── Estrelles de la nit (una és un gat) ── */
const celNit = document.getElementById('estrelles');
const DESTELL = 'M13 0C14.2 8.8 17.2 11.8 26 13c-8.8 1.2-11.8 4.2-13 13-1.2-8.8-4.2-11.8-13-13C8.8 11.8 11.8 8.8 13 0Z';
const GAT = 'M4 22c0-7 3-11 3-11L5 4l5 3c1.4-.5 4.6-.5 6 0l5-3-2 7s3 4 3 11H4Z';
for (let i = 0; i < 14; i++) {
  const esGat = i === 7;
  const s = document.createElementNS('http://www.w3.org/2000/svg','svg');
  s.setAttribute('viewBox','0 0 26 26');
  s.classList.add('estrella');
  s.style.width = (esGat ? 15 : 6 + Math.random()*10) + 'px';
  s.style.left = (4 + Math.random()*92) + '%';
  s.style.top = (4 + Math.random()*70) + '%';
