  s.innerHTML = `<path d="${esGat ? GAT : DESTELL}"/>`;
  if (esGat) { const t = document.createElementNS('http://www.w3.org/2000/svg','title'); t.textContent = 'miau'; s.appendChild(t); }
  celNit.appendChild(s);
}
/* Constel·lacions dels gats: silueta clara de gat assegut; s'uneixen soles en aparèixer, i es poden tocar */
const PUNTS_GAT = [[6,88],[16,95],[28,87],[33,64],[42,46],[52,30],[55,22],[58,10],[63,16],[68,15],[72,6],[76,18],[84,27],[84,37],[74,53],[74,71],[71,92]];
const graellaConst = document.getElementById('constel-graella');
const NOMS_GATS = ['Tofu', 'Tala', 'Iro', 'Ker'];
/* Mapa nom del gat -> foto (versió petita per a la constel·lació, gran per ampliar-la en clicar) */
const FOTOS_GATS = {
  "Tofu": "/assets/img/abdde339fd3.webp",
  "Tala": "/assets/img/a9edfe63518.webp",
  "Iro": "/assets/img/acb80881b08.webp",
  "Ker": "/assets/img/ad2c83b0520.webp"
};
const FOTOS_GATS_GRAN = {
  "Tofu": "/assets/img/a06fedfbc67.webp",
  "Tala": "/assets/img/af4292af940.webp",
  "Iro": "/assets/img/a77c2f9bd55.webp",
  "Ker": "/assets/img/a86525df898.webp"
};
[1, -1, 1, -1].forEach((mirall, idx) => {
  const nom = NOMS_GATS[idx];
  const item = document.createElement('div');
  item.classList.add('constellacio-item');

  const foto = document.createElement('img');
  foto.className = 'constellacio-foto';
  foto.loading = 'lazy';
  foto.alt = 'Foto de ' + nom;
  if (FOTOS_GATS[nom]) foto.src = FOTOS_GATS[nom];
  foto.addEventListener('click', e => {
    e.stopPropagation();
    obreLlumDirecta(FOTOS_GATS_GRAN[nom] || FOTOS_GATS[nom], 'Foto de ' + nom);
  });

  const g = document.createElementNS('http://www.w3.org/2000/svg','svg');
  g.setAttribute('viewBox','0 0 100 112');
  g.classList.add('constellacio');
  if (mirall < 0) g.style.transform = 'scaleX(-1)';
  const pts = PUNTS_GAT.map(([x,y]) => `${x},${y}`).join(' ');
  const cercles = PUNTS_GAT.map(([x,y],i) => `<circle cx="${x}" cy="${y}" r="${i%3===0?2.4:1.6}"/>`).join('');
  g.innerHTML = `<polyline points="${pts}"/>` + cercles +
    `<text x="50" y="108" text-anchor="middle"${mirall<0?' transform="scale(-1,1) translate(-100,0)"':''}>${nom}</text>`;
  g.addEventListener('pointerdown', () => { g.classList.toggle('unida'); item.classList.toggle('actiu'); });

  item.appendChild(foto);
  item.appendChild(g);
  graellaConst.appendChild(item);
});
const ioConst = ('IntersectionObserver' in window) && new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) {
    [...graellaConst.querySelectorAll('.constellacio')].forEach((g, i) => setTimeout(() => g.classList.add('unida'), 300 + i * 650));
    ioConst.disconnect();
  }
}), { threshold: 0.35 });
if (ioConst) ioConst.observe(graellaConst); else [...graellaConst.querySelectorAll('.constellacio')].forEach(g => g.classList.add('unida'));

const ioNit = ('IntersectionObserver' in window) && new IntersectionObserver(es => es.forEach(e => nitVisible = e.isIntersecting), { threshold: 0.2 });
if (ioNit) ioNit.observe(celNit.parentElement); else nitVisible = true;
function estrellaFugac() {
  const fg = document.createElement('div');
  fg.className = 'fugac2';
  // Direcció totalment lliure: qualsevol angle del cel
  const angle = Math.random() * Math.PI * 2;
  fg.style.left = (18 + Math.random() * 64) + '%';
  fg.style.top = (10 + Math.random() * 55) + '%';
  const durada = 1.6 + Math.random() * 0.9;
  fg.style.setProperty('--durada', durada + 's');
