    e.style.setProperty('--ey', (Math.random() * 20 - 4) + 'px');
    celNit.appendChild(e);
    setTimeout(() => e.remove(), 1000);
  }, durada * 110);
  setTimeout(() => fg.remove(), durada * 1000 + 200);
}
setInterval(() => { if (nitVisible && Math.random() > 0.3) estrellaFugac(); }, 6000);

</script>
