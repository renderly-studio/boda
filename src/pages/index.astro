<script is:inline>
const REDUIT = window.matchMedia('(prefers-reduced-motion: reduce)').matches;


let nitVisible = false;
/* ── Preloader: monograma bategant fins que tot està a punt ── */
const preload = document.getElementById('preload');
const tPre = Date.now();
window.addEventListener('load', () => {
  setTimeout(() => preload.classList.add('fet'), Math.max(0, 900 - (Date.now() - tPre)));
});
setTimeout(() => preload.classList.add('fet'), 3500); // xarxa lenta: no bloquejar mai


/* ── El sobre + confeti de destells ── */
const sobre = document.getElementById('sobre');
const DESTELL_PATH = 'M13 0C14.2 8.8 17.2 11.8 26 13c-8.8 1.2-11.8 4.2-13 13-1.2-8.8-4.2-11.8-13-13C8.8 11.8 11.8 8.8 13 0Z';
function soDeLacre() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const t0 = ctx.currentTime;
    // "crac" de paper i cera: ràfega de soroll filtrat + cop greu
    const durada = 0.22;
    const buf = ctx.createBuffer(1, ctx.sampleRate * durada, ctx.sampleRate);
    const dades = buf.getChannelData(0);
    for (let i = 0; i < dades.length; i++) dades[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / dades.length, 2.2);
    const soroll = ctx.createBufferSource(); soroll.buffer = buf;
    const filtre = ctx.createBiquadFilter();
    filtre.type = 'bandpass'; filtre.frequency.setValueAtTime(2400, t0);
    filtre.frequency.exponentialRampToValueAtTime(700, t0 + durada); filtre.Q.value = 0.8;
    const gs = ctx.createGain(); gs.gain.setValueAtTime(0.5, t0);
    soroll.connect(filtre).connect(gs).connect(ctx.destination);
    const osc = ctx.createOscillator(); osc.type = 'sine';
    osc.frequency.setValueAtTime(120, t0); osc.frequency.exponentialRampToValueAtTime(48, t0 + 0.16);
    const go = ctx.createGain();
    go.gain.setValueAtTime(0.35, t0); go.gain.exponentialRampToValueAtTime(0.001, t0 + 0.18);
    osc.connect(go).connect(ctx.destination);
    soroll.start(t0); osc.start(t0); osc.stop(t0 + 0.2);
  } catch { /* sense àudio, cap problema */ }
}
document.getElementById('segell').addEventListener('click', (ev) => {
  if (document.body.dataset.clauOk !== '1') return; // la porta la gestiona el bloc independent
  soDeLacre();
  if (navigator.vibrate) navigator.vibrate([28, 40, 18]);
  const r = ev.currentTarget.getBoundingClientRect();
  const ox = r.left + r.width/2, oy = r.top + r.height/2;
  for (let i = 0; i < 26; i++) {
    const c = document.createElementNS('http://www.w3.org/2000/svg','svg');
    c.setAttribute('viewBox','0 0 26 26');
    c.classList.add('confeti');
    const ang = Math.random() * Math.PI * 2, dist = 90 + Math.random() * 240;
    c.style.left = (ox - 8) + 'px';
    c.style.top = (oy - 8) + 'px';
    c.style.setProperty('--dx', Math.cos(ang) * dist + 'px');
    c.style.setProperty('--dy', (Math.sin(ang) * dist - 60) + 'px');
    c.style.setProperty('--gir', (Math.random() * 220 - 110) + 'deg');
    c.style.width = (9 + Math.random() * 13) + 'px';
    c.innerHTML = `<path d="${DESTELL_PATH}"/>`;
    document.body.appendChild(c);
    setTimeout(() => c.remove(), 1600);
  }
  sobre.classList.add('obert');
  document.body.classList.remove('tancat');
  try { localStorage.setItem('sobreObert', '1'); } catch {}
  const fes = document.getElementById('fes-scroll');
  setTimeout(() => fes.classList.add('visible'), 1800);
  window.addEventListener('scroll', () => fes.classList.remove('visible'), { once: true, passive: true });
});

</script>
<script is:inline>
/* ── Farolets lliures: els dos de la invitació (nets), només pels laterals.
   Si trepitgen informació, desapareixen del tot fins apartar-se. ── */
const farolets = [];
(function crearFarolets() {
  const tipus = [
    { src: '/assets/img/a6cca722918.webp', banda: 'esq' },
    { src: '/assets/img/a0d20825137.webp',  banda: 'dre' },
  ];
  tipus.forEach((cfg, i) => {
    const el = document.createElement('img');
    el.src = cfg.src;
    el.alt = '';
    el.className = 'farolet-lliure';
    const esMobil = window.innerWidth < 700;
    const mida = esMobil ? 34 + Math.random() * 14 : 78 + Math.random() * 40;
    el.style.width = mida + 'px';
    document.body.appendChild(el);
    farolets.push({ el, mida, banda: cfg.banda, x: 0, y: 120 + i * 300, tx: 0, ty: 0, fase: Math.random() * Math.PI * 2, idx: i });
  });
})();
const ESMOBIL_FL = window.innerWidth < 700;
function bandaX(fl) {
  // banda lateral: mai pel mig. Al mòbil, banda més estreta i el farolet
  // de l'esquerra queda més a prop del marge perquè no quedi tapat pel contingut.
  const ampladaBanda = ESMOBIL_FL
    ? Math.max(fl.mida + 4, window.innerWidth * 0.08)
    : Math.max(fl.mida + 10, window.innerWidth * 0.16);
  if (fl.banda === 'esq') return 4 + Math.random() * Math.max(4, ampladaBanda - fl.mida - 4);
  return window.innerWidth - ampladaBanda + Math.random() * Math.max(4, ampladaBanda - fl.mida - 4);
}
function nouDesti(fl) {
  fl.tx = bandaX(fl);
  // Al web, el farolet de l'esquerra es mou molt menys (roman més quiet).
  if (!ESMOBIL_FL && fl.banda === 'esq') {
    fl.ty = fl.ty || (window.innerHeight * 0.4);
    fl.ty += (Math.random() - 0.5) * 60;
    fl.ty = Math.max(70, Math.min(window.innerHeight - fl.mida * 2.4, fl.ty));
  } else {
    fl.ty = 70 + Math.random() * Math.max(120, window.innerHeight - fl.mida * 2.4 - 100);
  }
}
farolets.forEach(fl => { fl.x = bandaX(fl); nouDesti(fl); });
function derivaFarolets(ts) {
  farolets.forEach(fl => {
    const dx = fl.tx - fl.x, dy = fl.ty - fl.y;
    if (Math.hypot(dx, dy) < 12) nouDesti(fl);
    fl.x += dx * 0.0014; fl.y += dy * 0.0014;
    const balanceig = Math.sin(ts / 1500 + fl.fase) * 3;
    fl.el.style.transform = `translate(${fl.x}px, ${fl.y}px) rotate(${balanceig}deg)`;
  });
  if (!REDUIT) requestAnimationFrame(derivaFarolets);
}
if (REDUIT) {
  farolets.forEach((fl, i) => { fl.el.style.transform = `translate(${i ? window.innerWidth - fl.mida - 12 : 12}px, ${160 + i * 300}px)`; });
} else {
  requestAnimationFrame(derivaFarolets);
}
window.addEventListener('resize', () => farolets.forEach(nouDesti));

/* Al mòbil, com que el contingut ocupa gairebé tota l'amplada, els farolets
   es van "turnant": només un és visible a la vegada, alternant cada uns segons,
   en comptes de quedar amagats permanentment per xocar amb el text. */
let flTornActiu = 0;
if (ESMOBIL_FL) {
  setInterval(() => { flTornActiu = (flTornActiu + 1) % farolets.length; }, 5000);
}

setInterval(() => {
  const doc = document.documentElement;
  const pNit = doc.scrollTop / Math.max(1, doc.scrollHeight - window.innerHeight);
  const blocs = [...document.querySelectorAll('.contingut, .nav')].map(b => b.getBoundingClientRect());
  farolets.forEach(fl => {
    fl.el.classList.toggle('ences', pNit > 0.58);
    if (ESMOBIL_FL) {
      fl.el.classList.toggle('discret', fl.idx !== flTornActiu);
      return;
    }
    const r = fl.el.getBoundingClientRect();
    const sobreInfo = blocs.some(b => r.left < b.right && r.right > b.left && r.top < b.bottom && r.bottom > b.top);
    fl.el.classList.toggle('discret', sobreInfo);
  });
}, 250);

</script>
<script is:inline>
/* ── El dia de la boda: "és avui" i agenda en directe ── */
function aMadrid() {
  const p = new Intl.DateTimeFormat('ca-ES', { timeZone: 'Europe/Madrid', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }).formatToParts(new Date());
  const g = k => p.find(x => x.type === k).value;
  return { data: `${g('year')}-${g('month')}-${g('day')}`, minuts: parseInt(g('hour')) * 60 + parseInt(g('minute')) };
}
function modeAvui() {
  const ara = aMadrid();
  if (ara.data === '2027-07-02' || ara.data === '2027-07-03') {
    document.getElementById('compte').innerHTML = '<span class="es-avui">✦ ÉS AVUI ✦</span>';
    const hores = [18*60, 18*60+18, 19*60+19, 24*60];
    const min = ara.data === '2027-07-03' ? 24*60 : ara.minuts;
    document.querySelectorAll('.agenda li').forEach((li, i) => {
      const seguent = hores[i+1] !== undefined ? hores[i+1] : Infinity;
      li.classList.toggle('ara', min >= hores[i] && min < seguent);
    });
  } else if (ara.data > '2027-07-03') {
    document.getElementById('compte').innerHTML = '<span class="es-avui">✦ ENS HEM CASAT ✦</span>';
  }
}
modeAvui();
setInterval(modeAvui, 60000);



</script>
<script is:inline>
/* ── Compte enrere fins al sí, vull ── */
const OBJECTIU = new Date('2027-07-02T18:00:00+02:00').getTime();
function actualitzaCompte() {
  let d = Math.max(0, OBJECTIU - Date.now());
  const dies = Math.floor(d / 864e5); d -= dies * 864e5;
  const hores = Math.floor(d / 36e5); d -= hores * 36e5;
  const mins = Math.floor(d / 6e4); d -= mins * 6e4;
  document.getElementById('c-dies').textContent = dies;
  document.getElementById('c-postes').textContent = Math.ceil(Math.max(0, OBJECTIU - Date.now()) / 864e5);
  document.getElementById('c-hores').textContent = String(hores).padStart(2,'0');
  document.getElementById('c-mins').textContent = String(mins).padStart(2,'0');
  document.getElementById('c-segs').textContent = String(Math.floor(d/1e3)).padStart(2,'0');
}
actualitzaCompte();
setInterval(actualitzaCompte, 1000);

