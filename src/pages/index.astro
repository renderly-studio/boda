<script is:inline>
/* ── Lightbox de fotos ── */
const llum = document.getElementById('llum');
const llumImg = document.getElementById('llum-img');
function obreLlumDirecta(src, alt) {
  llumImg.src = src;
  llumImg.alt = alt || '';
  llum.classList.add('obert');
}
const fotosLlum = [...document.querySelectorAll('.tira img')];
let llumIdx = 0;
function obreLlum(i) {
  llumIdx = (i + fotosLlum.length) % fotosLlum.length;
  llumImg.src = fotosLlum[llumIdx].src;
  llum.classList.add('obert');
}
let arrossegat = false;
fotosLlum.forEach((im, i) => im.addEventListener('click', () => { if (!arrossegat) obreLlum(i); }));
/* Polaroids arrossegables (escriptori) */
if (window.matchMedia('(pointer: fine)').matches) {
  fotosLlum.forEach(im => {
    let px = 0, py = 0, dx = 0, dy = 0, actiu = false;
    im.addEventListener('pointerdown', e => {
      actiu = true; arrossegat = false;
      px = e.clientX - dx; py = e.clientY - dy;
      im.classList.add('agafada');
      im.setPointerCapture(e.pointerId);
    });
    im.addEventListener('pointermove', e => {
      if (!actiu) return;
      dx = e.clientX - px; dy = e.clientY - py;
      if (Math.hypot(dx, dy) > 6) arrossegat = true;
      im.style.setProperty('--dx', dx + 'px');
      im.style.setProperty('--dy', dy + 'px');
    });
    im.addEventListener('pointerup', () => { actiu = false; im.classList.remove('agafada'); setTimeout(() => arrossegat = false, 50); });
  });
}
document.getElementById('llum-ant').addEventListener('click', () => obreLlum(llumIdx - 1));
document.getElementById('llum-seg').addEventListener('click', () => obreLlum(llumIdx + 1));
document.getElementById('llum-tancar').addEventListener('click', () => llum.classList.remove('obert'));
llum.addEventListener('click', e => { if (e.target === llum) llum.classList.remove('obert'); });
window.addEventListener('deviceorientation', (e) => {
  if (!llum.classList.contains('obert') || e.gamma == null) return;
  const gx = Math.max(-14, Math.min(14, e.gamma / 3));
  const gy = Math.max(-10, Math.min(10, (e.beta - 45) / 4));
  llumImg.style.transform = `rotateY(${gx}deg) rotateX(${(-gy).toFixed(1)}deg)`;
});
document.addEventListener('keydown', e => {
  if (!llum.classList.contains('obert')) return;
  if (e.key === 'Escape') llum.classList.remove('obert');
  if (e.key === 'ArrowLeft') obreLlum(llumIdx - 1);
  if (e.key === 'ArrowRight') obreLlum(llumIdx + 1);
});

</script>
