  @media (min-width: 700px) { .constel-graella { grid-template-columns: repeat(4, 1fr); } }
  .constellacio-item {
    position: relative;
    display: flex;
    justify-content: center;
    width: clamp(120px, 34vw, 150px);
  }
  .constellacio {
    position: relative;
    width: clamp(120px, 34vw, 150px);
    overflow: visible;
    pointer-events: auto;
    cursor: pointer;
  }
  .constellacio-foto {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--crema);
    box-shadow: 0 8px 24px rgba(0,0,0,.4);
    opacity: 0;
    transform: scale(.8);
    cursor: zoom-in;
    pointer-events: none;
    transition: opacity .3s ease, transform .3s ease;
    z-index: 2;
