<script is:inline>
/* ── El cel que es pon amb l'scroll ── */
const cel = document.getElementById('cel');
const seccions = [...document.querySelectorAll('[data-sky]')];
function hex2rgb(h){h=h.replace('#','');return [0,2,4].map(i=>parseInt(h.slice(i,i+2),16));}
function rgb2css(c){return `rgb(${c.map(Math.round).join(',')})`;}
function barreja(a,b,t){return a.map((v,i)=>v+(b[i]-v)*t);}
let colors = seccions.map(s => hex2rgb(s.dataset.sky));
/* Mode vespre: si el visitant obre la web de nit, el cel comença més endins de la posta */
const horaLocal = new Date().getHours();
if (horaLocal >= 20 || horaLocal < 6) {
  colors = colors.map((c, i) => barreja(c, colors[Math.min(i + 1, colors.length - 1)], 0.45));
}
const progres = document.getElementById('progres');
let bandaPrevia = -1;
function destellDeBanda() {
  const d = document.createElementNS('http://www.w3.org/2000/svg','svg');
  d.setAttribute('viewBox','0 0 26 26');
  d.classList.add('transicio-destell');
  d.style.left = (14 + Math.random() * 72) + 'vw';
  d.style.top = (12 + Math.random() * 30) + 'vh';
  d.innerHTML = '<path d="M13 0C14.2 8.8 17.2 11.8 26 13c-8.8 1.2-11.8 4.2-13 13-1.2-8.8-4.2-11.8-13-13C8.8 11.8 11.8 8.8 13 0Z"/>';
  document.body.appendChild(d);
  setTimeout(() => d.remove(), 1100);
}
function pintaCel(){
  const doc = document.documentElement;
  progres.style.width = (Math.min(1, doc.scrollTop / (doc.scrollHeight - window.innerHeight)) * 100) + '%';
  const mig = window.innerHeight * 0.5;
  let i = 0;
  for (let k = 0; k < seccions.length; k++) {
    if (seccions[k].getBoundingClientRect().top + seccions[k].getBoundingClientRect().height/2 <= mig) i = k;
  }
  if (bandaPrevia !== -1 && i !== bandaPrevia) destellDeBanda();
  bandaPrevia = i;
  if (i < seccions.length - 1) {
    const r1 = seccions[i].getBoundingClientRect(), r2 = seccions[i+1].getBoundingClientRect();
    const c1 = r1.top + r1.height/2, c2 = r2.top + r2.height/2;
    const t = Math.min(1, Math.max(0, (mig - c1) / (c2 - c1)));
    const c = rgb2css(barreja(colors[i], colors[i+1], t));
    cel.style.backgroundColor = c;
    progres.style.backgroundColor = c;
    progres.style.filter = 'brightness(1.5)';
  } else {
    cel.style.backgroundColor = rgb2css(colors[i]);
    progres.style.backgroundColor = rgb2css(colors[i]);
    progres.style.filter = 'brightness(1.6)';
  }
}

/* ── L'astre fix: sol que canvia de color i que la nit mosega fins deixar només la lluna ── */
const astre = document.getElementById('astre');
const disc = document.getElementById('disc');
const mossec = document.getElementById('mossec');
const SOL_TARDA = [250, 210, 104];    // groc de tarda
const SOL_POSTA = [222, 106, 48];     // taronja de posta
const LLUNA_CREMA = [249, 244, 222];  // crema de la lluna
function corba(x){ return x < 0 ? 0 : x > 1 ? 1 : x * x * (3 - 2 * x); }
function mouSol(){
  const doc = document.documentElement;
  const p = Math.min(1, doc.scrollTop / (doc.scrollHeight - window.innerHeight));
  const tPosta = corba(p / 0.6);                 // groc → taronja mentre cau la tarda
  const tNit = corba((p - 0.62) / 0.24);         // la nit mossega el disc
  const color = tNit <= 0
    ? barreja(SOL_TARDA, SOL_POSTA, tPosta)
    : barreja(SOL_POSTA, LLUNA_CREMA, tNit);     // la part que queda es torna lluna
  disc.setAttribute('fill', rgb2css(color));
  // El mossec entra des de la dreta: de fora (185) fins a deixar una lluna creixent (66)
  mossec.setAttribute('cx', 185 - tNit * 119);
  astre.style.setProperty('--resplendor', String(1 - tNit)); // la resplendor del sol s'apaga
}
const fotosTira = [...document.querySelectorAll('.tira img')];
function parallaxFotos(){
  if (REDUIT || !fotosTira.length) return;
  const r = fotosTira[0].parentElement.getBoundingClientRect();
  const d = (r.top + r.height/2 - window.innerHeight/2) / window.innerHeight;
  fotosTira.forEach((im, i) => {
    im.style.translate = `0 ${(d * (i % 2 ? -26 : 26)).toFixed(1)}px`;
  });
}
const rajosEl = document.querySelector('.rajos');
const granDiaSec = document.getElementById('gran-dia');
function expandeixRajos(){
  if (!rajosEl) return;
  const r = granDiaSec.getBoundingClientRect();
  const p = Math.min(1, Math.max(0, 1 - r.top / window.innerHeight));
  const esc = 0.55 + 0.45 * p;
  rajosEl.style.transform = `translateY(-40%) scale(${esc.toFixed(3)})`;
  rajosEl.style.opacity = (0.25 + 0.75 * p).toFixed(2);
}
function enScroll(){ pintaCel(); mouSol(); parallaxFotos(); expandeixRajos(); }
enScroll();
window.addEventListener('scroll', enScroll, { passive: true });
window.addEventListener('resize', enScroll);

</script>
<script is:inline>
/* ── Aparició en fer scroll (ES5 + pla B: mai deixar el contingut invisible) ── */
(function () {
  var llista = document.querySelectorAll('.revela');
  function mostraTot() {
    for (var i = 0; i < llista.length; i++) llista[i].className += ' vist';
  }
  if (!('IntersectionObserver' in window)) { mostraTot(); return; }
  try {
    var io = new IntersectionObserver(function (entrades) {
      for (var i = 0; i < entrades.length; i++) {
        if (entrades[i].isIntersecting) entrades[i].target.classList.add('vist');
      }
    }, { threshold: 0.12 });
    for (var j = 0; j < llista.length; j++) io.observe(llista[j]);
  } catch (e) { mostraTot(); }
})();

</script>
<script is:inline>
/* ── Petjades que creuen la pantalla (un cop per secció clau) ── */
const POTA = '<svg viewBox="0 0 26 26"><ellipse cx="13" cy="19" rx="6.4" ry="5.2"/><circle cx="5.4" cy="10.5" r="2.7"/><circle cx="13" cy="7.6" r="2.9"/><circle cx="20.6" cy="10.5" r="2.7"/></svg>';
function rastreDePotes() {
  const puja = Math.random() < .5;
  for (let i = 0; i < 7; i++) {
    setTimeout(() => {
      const p = document.createElement('div');
      p.className = 'petjada';
      p.innerHTML = POTA;
      const x = 8 + i * 12;
      const y = puja ? 86 - i * 3 : 68 + i * 3;
      p.style.left = x + 'vw';
